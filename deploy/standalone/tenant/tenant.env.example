REM ================================================
REM 分控环境变量(由打包脚本根据签发的 license 自动填充)
REM ================================================
REM License 校验密钥(打包时从总控 /api/licenses 签发返回,明文仅此一次)
set LICENSE_KEY=
set LICENSE_SECRET=
REM 总控公网地址(分控向其校验 license)
set LICENSE_MASTER_URL=http://your-master-domain:8060
REM 总控/分控签名密钥(需与总控 application.yml 的 license.sign-secret 一致)
set LICENSE_SIGN_SECRET=bend-platform-license-sign-secret-2026-please-change-in-prod
REM 模式固定为分控
set LICENSE_MODE=tenant

REM 数据库(本地 green MySQL)
set DB_HOST=127.0.0.1
set DB_PORT=3306
set DB_NAME=bend_platform
set DB_USERNAME=root
set DB_PASSWORD=

REM JWT/AES(与总控可不同,分控独立签发本地用户 token)
set JWT_SECRET=
set AES_SECRET=

REM CORS: 分控直连后端调试时设 true,经 gateway 设 false
set CORS_ENABLED=false
