# 仓库内文本文件统一 LF，避免 Windows/macOS/Linux 协作时换行符 diff 噪音
* text=auto eol=lf

# Windows 脚本保留 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Shell 脚本显式 LF
*.sh text eol=lf

# 二进制资源不做换行转换
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.jar binary
*.class binary
*.pyc binary
*.pyo binary
*.zip binary
*.gz binary
*.tar binary
*.7z binary
*.pdf binary
