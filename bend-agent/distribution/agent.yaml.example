# ================================================
# Bend Agent 配置示例文件
# ================================================
# 此文件仅供参考，实际配置请修改 agent.yaml

aes:
  secret: "请与平台侧的 AES_SECRET 保持一致"

backend:
  # 分控架构下,这里指向【本机局域网内的分控服务地址】,不要填总控公网地址。
  # 打包 Agent 包时由打包脚本自动写入(商户无需手填)。
  base_url: "http://本机分控地址:8060"
  ws_url: "ws://本机分控地址:8060/ws/agent"
  api_prefix: "/api"
  # 分控架构下打包预置的注册码:Agent 首次启动用此码自动向本地分控激活,无需商户交互输入。
  # 留空则回退到交互式输入(旧流程)。
  registration_code: ""

agent:
  heartbeat_interval: 30
  reconnect_delay: 5
  max_reconnect_attempts: 10

video:
  fps: 10
  capture_interval: 0.1
  max_frame_buffer: 5

template:
  threshold: 0.8
  template_dir: "./templates"
  cache_enabled: true

scene:
  detection_interval: 0.5
  confidence_threshold: 0.7

input:
  click_delay: 0.1
  key_press_delay: 0.05
  move_duration: 0.2

automation:
  max_retries: 3
  retry_delay: 2
  action_cooldown: 1

# Step4 档案 OCR（PaddleOCR；裁剪区见 profile_name_reader.py）
ocr:
  engine: onnxruntime
  det_model: PP-OCRv6_tiny_det
  rec_model: PP-OCRv6_tiny_rec
  enable_mkldnn: true
  cpu_threads: 0
  min_crop_brightness: 25

task:
  max_concurrent: 100
  max_xbox_sessions: 100
  result_ttl: 3600
  cleanup_interval: 300

logging:
  level: "INFO"
  file: "./logs/agent.log"
  max_size: 10
  backup_count: 5

window:
  default_width: 1280
  default_height: 720
  min_width: 800
  min_height: 600
