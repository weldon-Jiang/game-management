# ================================================
# Bend Agent 配置示例文件
# ================================================
# 此文件仅供参考，实际配置请修改 agent.yaml

aes:
  secret: "请与平台侧的 AES_SECRET 保持一致"

backend:
  base_url: "http://你的服务器地址:8060"
  ws_url: "ws://你的服务器地址:8060/ws/agents"
  api_prefix: "/api"

agent:
  heartbeat_interval: 30
  reconnect_delay: 5
  max_reconnect_attempts: 10

video:
  fps: 10
  capture_interval: 0.1
  max_frame_buffer: 5

template:
  threshold: 0.8
  template_dir: "./templates"
  cache_enabled: true

scene:
  detection_interval: 0.5
  confidence_threshold: 0.7

input:
  click_delay: 0.1
  key_press_delay: 0.05
  move_duration: 0.2

automation:
  max_retries: 3
  retry_delay: 2
  action_cooldown: 1

task:
  max_concurrent: 100
  max_xbox_sessions: 100
  result_ttl: 3600
  cleanup_interval: 300

logging:
  level: "INFO"
  file: "./logs/agent.log"
  max_size: 10
  backup_count: 5

window:
  default_width: 1280
  default_height: 720
  min_width: 800
  min_height: 600
