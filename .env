# ============================================
# Bend Platform Docker 环境配置
# ============================================
# 使用方式：
#   1. 默认值适用于本地开发
#   2. 生产环境请修改对应配置
#   3. 支持通过环境变量覆盖
# ============================================

# ============================================
# 服务配置
# ============================================

# Spring Profile (dev/test/prod)
SPRING_PROFILES_ACTIVE=prod

# 重启策略 (no/always/unless-stopped/on-failure)
RESTART_POLICY=unless-stopped

# ============================================
# MySQL 数据库配置
# ============================================
MYSQL_ROOT_PASSWORD=D$U@GAMECeKfidb
MYSQL_DATABASE=bend_platform
MYSQL_USER=root
MYSQL_PASSWORD=D$U@GAMECeKfidb
# MySQL 端口映射 (格式: IP:Port)
MYSQL_PORT=127.0.0.1:3306

# ============================================
# Redis 配置
# ============================================
REDIS_PASSWORD=D$U@GAMECeKfi
# Redis 端口映射 (格式: IP:Port)
REDIS_PORT=127.0.0.1:6379

# ============================================
# 后端服务配置
# ============================================
# 后端 Dockerfile 路径 (默认: Dockerfile.backend)
DOCKERFILE_BACKEND=Dockerfile.backend

# ============================================
# API 网关配置
# ============================================
# Gateway Dockerfile 路径 (默认: Dockerfile.gateway)
DOCKERFILE_GATEWAY=Dockerfile.gateway
# Gateway 端口映射 (格式: IP:Port)
GATEWAY_PORT=0.0.0.0:8060

# ============================================
# 前端配置
# ============================================
# 前端 Dockerfile 路径 (默认: Dockerfile.frontend)
DOCKERFILE_FRONTEND=Dockerfile.frontend
# 前端端口映射 (格式: IP:Port)
FRONTEND_PORT=0.0.0.0:3090

# ============================================
# 安全配置
# ============================================

# JWT 密钥 (用于签名 JWT Token)
JWT_SECRET=jU1k0/WdUIamaqVsvsGBsLMwiBG2DAE26J+HutQuT0k=
# JWT 过期时间 (毫秒, 默认 24 小时)
JWT_EXPIRATION=86400000

# AES 密钥 (用于加密敏感数据)
AES_SECRET=0sedzo/xcWVHjwKvJAk4lg==

# ============================================
# CORS 配置
# ============================================
# 后端 CORS 是否启用 (true/false)
# Docker 部署时建议 false, 由 Gateway 统一处理
CORS_ENABLED=false

# ============================================
# 系统配置
# ============================================
TZ=Asia/Shanghai
