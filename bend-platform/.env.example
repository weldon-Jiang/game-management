# ================================================
# Bend Platform 环境变量配置示例
# ================================================
# 复制此文件为 .env 并填入实际值

# ================================================
# 数据库配置
# ================================================
DB_URL=jdbc:mysql://localhost:3306/bend_platform?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_db_password_here

# 数据库连接池
DB_POOL_MIN_IDLE=5
DB_POOL_MAX_SIZE=20
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000
DB_CONNECTION_TIMEOUT=3000

# ================================================
# Redis配置
# ================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=your_redis_password_here
REDIS_TIMEOUT=6000
REDIS_SSL=false

# Redis连接池
REDIS_POOL_MAX_ACTIVE=10
REDIS_POOL_MAX_IDLE=8
REDIS_POOL_MAX_WAIT=100
REDIS_POOL_MIN_IDLE=2

# ================================================
# JWT配置
# ================================================
# JWT签名密钥（生产环境应使用至少32位的复杂随机字符串）
JWT_SECRET=your_jwt_secret_key_at_least_32_characters_long
JWT_EXPIRATION=86400000

# ================================================
# AES加密配置
# ================================================
# AES加密密钥（必须是16、24或32字节）
AES_SECRET=your_aes_secret_key_16

# ================================================
# CORS跨域配置
# ================================================
# 多个域名用逗号分隔
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3090

# ================================================
# 服务配置
# ================================================
SERVER_PORT=8090
