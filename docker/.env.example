# ============================================
# Bend Platform 环境变量配置
# ============================================
# 复制此文件为 .env 并修改相应配置
# cp .env.example ../.env
# ============================================

# ============================================
# Docker Compose 全局配置
# ============================================
# 重启策略：always | unless-stopped | on-failure
RESTART_POLICY=unless-stopped

# Spring Profile
SPRING_PROFILES_ACTIVE=prod

# 时区
TZ=Asia/Shanghai

# ============================================
# MySQL 数据库配置
# ============================================
MYSQL_ROOT_PASSWORD=your_strong_root_password_here
MYSQL_DATABASE=bend_platform
MYSQL_USER=bend_user
MYSQL_PASSWORD=your_strong_user_password_here

# MySQL 端口映射（默认仅本地访问）
MYSQL_PORT=127.0.0.1:3306

# ============================================
# Redis 配置
# ============================================
REDIS_PASSWORD=your_redis_password_here

# Redis 端口映射（默认仅本地访问）
REDIS_PORT=127.0.0.1:6379

# ============================================
# JWT 配置
# ============================================
# JWT 密钥（至少32字符）
JWT_SECRET=your-very-long-secret-key-at-least-32-characters-here
JWT_EXPIRATION=86400000

# ============================================
# AES 加密配置
# ============================================
# AES 密钥（16/24/32 字符）
AES_SECRET=your-aes-secret-key-here

# ============================================
# CORS 配置
# ============================================
# 是否启用 CORS（生产环境建议设为 false）
CORS_ENABLED=false

# ============================================
# 服务端口配置
# ============================================
# 网关端口（0.0.0.0 表示允许外部访问）
GATEWAY_PORT=0.0.0.0:8060

# 前端端口（0.0.0.0 表示允许外部访问）
FRONTEND_PORT=0.0.0.0:3090
