# ============================================
# Bend Platform Git 忽略配置
# ============================================

# 环境变量（敏感配置 — 仅排除含真实密钥的文件，模板 .example 应提交）
.env
.env.local
.env.sit
.env.prod
.env.tenant

# Docker 环境变量（通配覆盖所有 env 变体：.env / .env.sit / .env.prod / .env.tenant）
# 注意：docker/.env.example 是模板，已通过 git 跟踪，不受此规则影响
docker/.env*

# 日志
*.log
logs/
**/logs/

# 临时文件
*.tmp
*.temp
*.swp
*.swo
*.bak
*.backup

# IDE
.idea/
.vscode/
*.iml

# 系统文件
.DS_Store
Thumbs.db

# ============================================
# 构建产物
# ============================================
bend-platform/target/
bend-platform-web/dist/
bend-agent/dist/
.cursor/

# 绿色生产包 —— 构建中间产物与输出（不入库）
#   staging/     green 资源 (JRE/MySQL/Redis/nginx 二进制)
#   */staging/   各包 staging 中间产物
#   */Output/    ISCC 编译输出 (.exe 安装包)
deploy/standalone/staging/
deploy/standalone/*/staging/
deploy/standalone/*/Output/

# Python 缓存与测试缓存
__pycache__/
**/__pycache__/
*.pyc
*.pyo
.pytest_cache/
**/.pytest_cache/

# Agent 运行时令牌（敏感）
bend-agent/tokens/
docs/
.claude/
.trae/

# 本地测试临时文件
insert_license.sql
merchant_data.sql
