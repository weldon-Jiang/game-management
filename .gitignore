# ============================================
# Bend Platform Git 忽略配置
# ============================================

# 环境变量（敏感配置）
.env
.env.local
.env.dev
.env.sit
.env.prod
.env.example

# Docker（通配覆盖所有 env 变体：.env.dev / .env.sit / .env.prod / .env.tenant）
docker/.env*

# 日志
*.log
logs/
**/logs/

# 临时文件
*.tmp
*.temp
*.swp
*.swo
*.bak
*.backup

# IDE
.idea/
.vscode/
*.iml

# 系统文件
.DS_Store
Thumbs.db

# 构建产物
bend-platform/target/
bend-platform-web/dist/
bend-agent/dist/
.cursor/

# Python 缓存与测试缓存
__pycache__/
**/__pycache__/
*.pyc
*.pyo
.pytest_cache/
**/.pytest_cache/

# Agent 运行时令牌（敏感）
bend-agent/tokens/
docs/
.claude/
.trae/